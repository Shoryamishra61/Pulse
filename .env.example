# PULSE CRM — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (optional — runs in demo mode without it)
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse

# Webhook secret for HMAC-SHA256 signature verification
WEBHOOK_SECRET=pulse-webhook-secret-v1

# Channel Service URL (default: http://localhost:3001)
CHANNEL_SERVICE_URL=http://localhost:3001
